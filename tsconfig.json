{
  "compilerOptions": {
    "module": "ESNext",
    "target": "es2019",
    "sourceMap": true,
    "outDir": "./dist/",
    "noImplicitAny": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "shared/*": [
        "./src/shared/*"
      ],
      "resume/*": [
        "./src/Resume/*"
      ],
    },
    "allowJs": true,
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "exclude": [
    "node_modules"
  ],
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS",
      "types": [
        "vite/client",
        "vite-plugin-svgr/client",
      ]
    }
  }
}